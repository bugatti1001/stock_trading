# Database Configuration
DATABASE_URL=sqlite:///./data/stock_trading.db

# API Keys
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
NEWS_API_KEY=your_news_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# Xueqiu (雪球) — for CN A-shares and HK stocks
# Get token from browser cookies: login to xueqiu.com, open DevTools, find xq_a_token
# If not set, the scraper will auto-fetch a token by visiting the homepage
XUEQIU_TOKEN=

# Google Custom Search (for news fetching)
GOOGLE_CUSTOM_SEARCH_API_KEY=your_google_cse_api_key_here
GOOGLE_CUSTOM_SEARCH_CX=your_google_cse_cx_here

# Application Settings
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here

# Data Collection Settings
AUTO_UPDATE_ENABLED=True
UPDATE_INTERVAL_HOURS=24

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
